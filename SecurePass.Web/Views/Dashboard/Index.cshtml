@model IEnumerable<SecurePass.Core.Entities.Visitor>
@{
    ViewData["Title"] = "Yönetici Analitik Paneli";
}

<!-- Chart.js and Animations -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
    .stat-card { transition: transform 0.2s; cursor: pointer; }
    .stat-card:hover { transform: translateY(-5px); }
    .real-time-pulse {
        width: 10px; height: 10px; background: #10b981; border-radius: 50%;
        display: inline-block; margin-right: 5px;
        animation: pulse-animation 2s infinite;
    }
    @@keyframes pulse-animation {
        0% { box-shadow: 0 0 0 0px rgba(16, 185, 129, 0.7); }
        100% { box-shadow: 0 0 0 10px rgba(16, 185, 129, 0); }
    }
</style>

<div class="row g-4 mb-4">
    <!-- Real-Time Occupancy -->
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0 shadow-sm h-100 bg-white">
            <div class="card-body">
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted small fw-bold text-uppercase">@(System.Threading.Thread.CurrentThread.CurrentCulture.Name == "tr-TR" ? "CANLI TESİS MONİTÖRÜ" : "LIVE FACILITY MONITOR")</span>
                    <span class="real-time-pulse"></span>
                </div>
                <h2 class="fw-bold text-dark mb-1">@ViewBag.CurrentVisitors</h2>
                <div class="progress" style="height: 6px;">
                    <div class="progress-bar bg-success" role="progressbar" style="width: @ViewBag.OccupancyRate%"></div>
                </div>
                <small class="text-muted d-block mt-2">@(System.Threading.Thread.CurrentThread.CurrentCulture.Name == "tr-TR" ? "Kapasite Kullanımı" : "Capacity Usage"): %@ViewBag.OccupancyRate</small>
            </div>
        </div>
    </div>

    <!-- Overstay Alert Card -->
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0 shadow-sm h-100 @(ViewBag.OverstayCount > 0 ? "bg-danger text-white animate__animated animate__pulse animate__infinite" : "bg-white")">
            <div class="card-body">
                <span class="@(ViewBag.OverstayCount > 0 ? "text-white" : "text-muted") small fw-bold d-block mb-3 text-uppercase">
                    @(System.Threading.Thread.CurrentThread.CurrentCulture.Name == "tr-TR" ? "SÜRE AŞIMI ALARMI" : "OVERSTAY ALERTS")
                </span>
                <h2 class="fw-bold mb-1">@ViewBag.OverstayCount</h2>
                <span class="@(ViewBag.OverstayCount > 0 ? "badge bg-white text-danger" : "text-muted small")">
                    @(ViewBag.OverstayCount > 0 ? "Acil Müdahale!" : "Tüm çıkışlar normal")
                </span>
            </div>
        </div>
    </div>
    
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0 shadow-sm h-100 bg-white">
            <div class="card-body">
                <span class="text-muted small fw-bold d-block mb-3 text-uppercase">@(System.Threading.Thread.CurrentThread.CurrentCulture.Name == "tr-TR" ? "BUGÜNKÜ GİRİŞLER" : "TODAY'S ENTRIES")</span>
                <h2 class="fw-bold text-primary mb-1">@ViewBag.TodayVisitors</h2>
                <span class="badge bg-primary-subtle text-primary">+12%</span>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0 shadow-sm h-100 bg-white">
            <div class="card-body">
                <span class="text-muted small fw-bold d-block mb-3 text-uppercase">@(System.Threading.Thread.CurrentThread.CurrentCulture.Name == "tr-TR" ? "TOPLAM ARŞİV" : "TOTAL ARCHIVE")</span>
                <h2 class="fw-bold text-dark mb-1">@ViewBag.TotalVisitors</h2>
                <span class="text-muted small">All time</span>
            </div>
        </div>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card border-0 shadow-sm h-100 bg-primary text-white">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <span class="opacity-75 small fw-bold d-block mb-1 text-uppercase">@(System.Threading.Thread.CurrentThread.CurrentCulture.Name == "tr-TR" ? "SİSTEM ARAÇLARI" : "SYSTEM TOOLS")</span>
                        <h5 class="fw-bold mb-0"><i class="fa-solid fa-shield-check me-2"></i>Secure v2.4</h5>
                    </div>
                    <form asp-action="SeedData" method="post" class="mt-2">
                        <button type="submit" class="btn btn-sm btn-light w-100 fw-bold">
                            <i class="fa-solid fa-database me-1"></i> @(System.Threading.Thread.CurrentThread.CurrentCulture.Name == "tr-TR" ? "Veri Yükle" : "Seed Data")
                        </button>
                    </form>
                    <form asp-action="ClearAllData" method="post" class="mt-2" onsubmit="return confirm('Tüm ziyaretçi verileri kalıcı olarak silinecektir. Emin misiniz?');">
                        <button type="submit" class="btn btn-sm btn-outline-light w-100 fw-bold border-0">
                            <i class="fa-solid fa-trash-can me-1"></i> Tümünü Temizle
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

<div class="row g-4 mb-4">
    <!-- Hourly Intensity Heatmap/Line Chart -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h6 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-chart-area me-2"></i>@(System.Threading.Thread.CurrentThread.CurrentCulture.Name == "tr-TR" ? "Yoğunluk Analizi" : "Intensity Analysis")</h6>
            </div>
            <div class="card-body">
                <canvas id="intensityChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>

    <!-- Category Distribution -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h6 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-chart-pie me-2"></i>@(System.Threading.Thread.CurrentThread.CurrentCulture.Name == "tr-TR" ? "Ziyaretçi Dağılımı" : "Visitor Distribution")</h6>
            </div>
            <div class="card-body">
                <canvas id="categoryChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
        <h6 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-clock-rotate-left me-2"></i>@(System.Threading.Thread.CurrentThread.CurrentCulture.Name == "tr-TR" ? "Son Hareketler" : "Recent Activity")</h6>
        <a asp-controller="Visitor" asp-action="Index" class="btn btn-sm btn-light border fw-bold px-3">View All</a>
    </div>
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="bg-light small">
                <tr>
                    <th class="ps-4">ZİYARETÇİ</th>
                    <th>FİRMA</th>
                    <th>ZAMAN</th>
                    <th class="text-center">DURUM</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                    @item.FirstName[0]@item.LastName[0]
                                </div>
                                <span class="fw-semibold small">@item.FirstName @item.LastName</span>
                            </div>
                        </td>
                        <td><span class="badge bg-light text-dark border fw-normal">@(item.Company ?? "Bireysel")</span></td>
                        <td class="small">@item.VisitDate.ToString("HH:mm")</td>
                        <td class="text-center">
                            @if(item.IsInside) {
                                <span class="badge rounded-pill bg-success-subtle text-success small px-3">İçeride</span>
                            } else {
                                <span class="badge rounded-pill bg-secondary-subtle text-secondary small px-3">Ayrıldı</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    // Intensity Chart (Line/Area)
    const ctxIntensity = document.getElementById('intensityChart').getContext('2d');
    new Chart(ctxIntensity, {
        type: 'line',
        data: {
            labels: ['08:00', '09:00', '10:00', '11:00', '12:00', '13:00', '14:00', '15:00', '16:00', '17:00', '18:00'],
            datasets: [{
                label: 'Ziyaretçi Sayısı',
                data: @Html.Raw(Json.Serialize(ViewBag.HourlyStats)),
                borderColor: '#3b82f6',
                backgroundColor: 'rgba(59, 130, 246, 0.1)',
                fill: true,
                tension: 0.4,
                pointRadius: 4,
                pointBackgroundColor: '#fff',
                pointBorderColor: '#3b82f6',
                pointBorderWidth: 2
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 } },
                x: { grid: { display: false } }
            }
        }
    });

    // Category Chart (Doughnut)
    const ctxCategory = document.getElementById('categoryChart').getContext('2d');
    new Chart(ctxCategory, {
        type: 'doughnut',
        data: {
            labels: ['Kurumsal', 'Bireysel'],
            datasets: [{
                data: [@ViewBag.CorporateCount, @ViewBag.IndividualCount],
                backgroundColor: ['#3b82f6', '#94a3b8'],
                borderWidth: 0,
                cutout: '75%'
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } }
            }
        }
    });
</script>