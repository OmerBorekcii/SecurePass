@model SecurePass.Core.Entities.User
@{
    ViewData["Title"] = "Yeni Personel Kaydı";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h4 class="fw-bold mb-4">Personel Tanımla</h4>
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">KULLANICI ADI</label>
                        <input asp-for="Username" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">ŞİFRE</label>
                        <input asp-for="Password" type="password" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">YETKİ ROLÜ</label>
                        <select asp-for="Role" class="form-select">
                            <option value="Reception">Resepsiyon (Operasyon)</option>
                            <option value="Admin">Sistem Yöneticisi (Admin)</option>
                        </select>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary w-100 fw-bold py-2">Kaydet</button>
                        <a asp-action="Index" class="btn btn-light border w-100 fw-bold py-2">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>