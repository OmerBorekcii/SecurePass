## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This file is a combination of the VisualStudio.gitignore from
## https://github.com/github/gitignore and some additional common
## exclusions.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
#.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml

# Build log of MSBuild
*.aps
*.intermediate.manifest
*.pdb
*.tmp
*.tmp_proj
*.log
*.tlog
*.unsuccessfulbuild
*.lastbuildstate

# Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
out/
wwwroot/lib/
wwwroot/dist/

# Entity Framework 
# Note: Migrations are usually committed, but some logs or DBs are not.
*.db

# User-specific files
.env
.env.*

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet Localization
#!**/[Pp]ackages/Microsoft. some-package.localization/
